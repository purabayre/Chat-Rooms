<%- include('partials/header') %>

<style>
  /* Hero layout */
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 60px 10%;
    min-height: 90vh;
    background: linear-gradient(135deg, #4a90e2, #6fc3ff);
    color: white;
    font-family: Arial, sans-serif;
  }

  /* Left content */
  .hero-content {
    max-width: 500px;
  }

  .hero-content h1 {
    font-size: 42px;
    line-height: 1.2;
    margin-bottom: 15px;
  }

  .hero-sub {
    font-size: 16px;
    margin-bottom: 25px;
    color: #eaf4ff;
  }

  /* Buttons */
  .hero-actions {
    display: flex;
    gap: 10px;
  }

  .btn {
    padding: 10px 16px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  .btn-lg {
    font-size: 16px;
    padding: 12px 18px;
  }

  .btn-primary {
    background: #ffffff;
    color: #4a90e2;
    font-weight: bold;
  }

  .btn-primary:hover {
    background: #e6f0ff;
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid #ffffff;
    color: #ffffff;
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  /* Right side chat bubbles */
  .hero-art {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 300px;
  }

  .bubble {
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 14px;
    max-width: 80%;
    animation: fadeInUp 0.5s ease both;
  }

  .bubble-in {
    background: #ffffff;
    color: #333;
    align-self: flex-start;
  }

  .bubble-out {
    background: #2d7be5;
    color: white;
    align-self: flex-end;
  }

  /* Animation */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="hero">
  <div class="hero-content">
    <h1>Real-time chat,<br />no frills.</h1>
    <p class="hero-sub">
      Create rooms, invite friends, chat live — messages persist, typing
      indicators included.
    </p>
    <div class="hero-actions">
      <a href="/auth/register" class="btn btn-primary btn-lg">Get started</a>
      <a href="/auth/login" class="btn btn-ghost btn-lg">Sign in</a>
    </div>
  </div>
  <div class="hero-art">
    <div class="bubble bubble-in">Hey! Is this working? 👋</div>
    <div class="bubble bubble-out">Yes! Works perfectly 🎉</div>
    <div class="bubble bubble-in">Alice is typing...</div>
  </div>
</div>

<%- include('partials/footer') %>
