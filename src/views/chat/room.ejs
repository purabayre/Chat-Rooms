<%- include('../partials/header') %>

<style>

.chat-layout {
  display: flex;
  height: 90vh;
  background: #f5f7fa;
  font-family: Arial, sans-serif;
}


.chat-sidebar {
  width: 260px;
  background: #ffffff;
  border-right: 1px solid #e6e6e6;
  padding: 15px;
  display: flex;
  flex-direction: column;
}

.sidebar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.invite-section {
  margin-bottom: 20px;
}

.hint {
  font-size: 12px;
  color: #777;
}

.invite-copy-row {
  display: flex;
  gap: 5px;
  margin-top: 5px;
}

.invite-link-input {
  flex: 1;
  font-size: 12px;
  padding: 5px;
  border: 1px solid #ddd;
  border-radius: 5px;
}


.online-users-section h4 {
  margin-bottom: 8px;
}

.online-count-badge {
  background: #e6f4ea;
  color: #2e7d32;
  padding: 2px 6px;
  border-radius: 12px;
  font-size: 12px;
}

.online-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.online-user {
  font-size: 13px;
  padding: 4px 0;
  border-bottom: 1px solid #f0f0f0;
}


.chat-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}


.messages-wrap {
  flex: 1;
  overflow-y: auto;
  padding: 15px;
}

.messages {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.message-row {
  display: flex;
  align-items: flex-end;
  gap: 8px;
}

.message-row.mine {
  flex-direction: row-reverse;
}

.avatar-sm {
  width: 32px;
  height: 32px;
  border-radius: 50%;
}


.message-bubble-wrap {
  max-width: 65%;
}

.message-sender {
  font-size: 11px;
  color: #777;
}

.message-bubble {
  background: #ffffff;
  padding: 8px 12px;
  border-radius: 12px;
  font-size: 14px;
  margin-top: 2px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.05);
}

.message-row.mine .message-bubble {
  background: #4a90e2;
  color: #fff;
}

.message-time {
  font-size: 10px;
  color: #999;
  margin-top: 2px;
  display: block;
}


.system-msg {
  text-align: center;
  font-size: 12px;
  color: #888;
}


.typing-indicator {
  font-size: 12px;
  color: #777;
  padding: 5px 15px;
}


.chat-input-bar {
  display: flex;
  padding: 10px;
  border-top: 1px solid #e6e6e6;
  background: #fff;
}

.chat-input {
  flex: 1;
  padding: 10px;
  border-radius: 20px;
  border: 1px solid #ddd;
  font-size: 14px;
  margin-right: 8px;
}

.chat-input:focus {
  outline: none;
  border-color: #4a90e2;
}


.btn {
  padding: 8px 12px;
  border-radius: 6px;
  border: none;
  cursor: pointer;
}

.btn-primary {
  background: #4a90e2;
  color: #fff;
}

.btn-primary:hover {
  background: #357abd;
}

.btn-ghost {
  background: #eef3f8;
}

.btn-ghost:hover {
  background: #dde7f0;
}

.btn-sm {
  font-size: 12px;
  padding: 5px 8px;
}

.message-bubble-wrap {
  max-width: 65%;
  position: relative;
}

/* hover popup */
.reaction-popup {
  position: absolute;
  bottom: 100%;
  left: 0;
  transform: translateY(-5px);
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 20px;
  padding: 4px 8px;
  display: flex;
  gap: 6px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  opacity: 0;
  pointer-events: none;
  transition: 0.2s;
}

.message-bubble-wrap:hover .reaction-popup {
  opacity: 1;
  pointer-events: auto;
}

.reaction-popup button {
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 16px;
}

.reaction-pill {
  display: inline-block;
  background: #eef3f8;
  border-radius: 12px;
  padding: 2px 6px;
  font-size: 12px;
  margin-right: 4px;
  margin-top: 4px;
}

.reactions {
  margin-top: 2px;
}

</style>

<div class="chat-layout">
  <aside class="chat-sidebar">
    <div class="sidebar-header">
      <h3>#<%= room.name %></h3>
      <a href="/chat" class="btn btn-ghost btn-sm">← Rooms</a>
    </div>

    <% if (inviteToken) { %>
    <div class="invite-section">
      <p class="hint">Private — share this link:</p>
      <div class="invite-copy-row">
        <input type="text" id="invite-link" class="invite-link-input" readonly value="" />
        <button class="btn btn-ghost btn-sm" onclick="copyInviteLink()">Copy</button>
      </div>
    </div>
    <% } %>

    <div class="online-users-section">
      <h4>Online <span id="online-count" class="online-count-badge">0</span></h4>
      <ul id="online-list" class="online-list"></ul>
    </div>
  </aside>

  <div class="chat-main">
    <div class="messages-wrap" id="messages-wrap">
      <div id="messages" class="messages">
        <% messages.forEach(msg => { %>
          <div class="message-row <%= msg.sender._id.toString() === currentUserId ? 'mine' : 'theirs' %>">
            <img
              src="<%= msg.sender.avatarPath || '/img/default-avatar.png' %>"
              alt="<%= msg.sender.name %>"
              class="avatar avatar-sm"
            />
            <div class="message-bubble-wrap">
              <span class="message-sender"><%= msg.sender.name %></span>

              <!-- hover popup -->
              <div class="reaction-popup">
                <button onclick="react('<%= msg._id %>', '👍')">👍</button>
                <button onclick="react('<%= msg._id %>', '❤️')">❤️</button>
                <button onclick="react('<%= msg._id %>', '😂')">😂</button>
              </div>

              <div class="message-bubble"><%= msg.text %></div>

              <!-- reactions below message -->
              <div class="reactions" id="react-<%= msg._id %>"></div>

              <span class="message-time">
                <%= new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) %>
              </span>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="typing-indicator" id="typing-indicator"></div>

    <div class="chat-input-bar">
      <input
        type="text"
        id="msg-input"
        class="chat-input"
        placeholder="Type a message…"
        autocomplete="off"
        maxlength="2000"
      />
      <button id="send-btn" class="btn btn-primary">Send</button>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const ROOM_ID      = '<%= room._id %>';
const CURRENT_UID  = '<%= currentUserId %>';
const INVITE_TOKEN = '<%= inviteToken || "" %>';

if (INVITE_TOKEN) {
  document.getElementById('invite-link').value =
    location.origin + '/chat/rooms/' + ROOM_ID + '?token=' + INVITE_TOKEN;
}

function copyInviteLink() {
  const link = document.getElementById('invite-link').value;
  navigator.clipboard.writeText(link).then(() => alert('Copied!'));
}

const socket       = io();
const messagesEl   = document.getElementById('messages');
const wrapEl       = document.getElementById('messages-wrap');
const inputEl      = document.getElementById('msg-input');
const sendBtn      = document.getElementById('send-btn');
const typingEl     = document.getElementById('typing-indicator');

function scrollBottom() { wrapEl.scrollTop = wrapEl.scrollHeight; }

function formatTime(d) {
  return new Date(d).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

function escapeHtml(str) {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function appendMessage(msg) {
  const isMine = msg.sender._id === CURRENT_UID || String(msg.sender._id) === CURRENT_UID;

  const row = document.createElement('div');
  row.className = 'message-row ' + (isMine ? 'mine' : 'theirs');

  row.innerHTML = `
    <img src="${msg.sender.avatarPath || '/img/default-avatar.png'}"
         alt="${escapeHtml(msg.sender.name)}" class="avatar avatar-sm" />
    <div class="message-bubble-wrap">
      <span class="message-sender">${escapeHtml(msg.sender.name)}</span>

      <div class="reaction-popup">
        <button onclick="react('${msg._id}', '👍')">👍</button>
        <button onclick="react('${msg._id}', '❤️')">❤️</button>
        <button onclick="react('${msg._id}', '😂')">😂</button>
      </div>

      <div class="message-bubble" data-id="${msg._id}">
        ${escapeHtml(msg.text)}
      </div>

      <div class="reactions" id="react-${msg._id}"></div>

      <span class="message-time">${formatTime(msg.createdAt)}</span>
    </div>`;

  messagesEl.appendChild(row);
  scrollBottom();

  renderReactions(msg._id, msg.reactions || {});
}

function react(messageId, emoji) {
  socket.emit("react-message", {
    roomId: ROOM_ID,
    messageId,
    emoji
  });
}

function renderReactions(messageId, reactions) {
  const container = document.getElementById(`react-${messageId}`);
  if (!container) return;

  container.innerHTML = "";

  for (let emoji in reactions) {
    const count = reactions[emoji];

    const span = document.createElement("span");
    span.className = "reaction-pill";
    span.textContent = `${emoji} ${count}`;

    container.appendChild(span);
  }
}

socket.emit("join-room", { roomId: ROOM_ID });

socket.on("new-message", (msg) => {
  appendMessage(msg);
});

socket.on("message-reacted", ({ messageId, reactions }) => {
  renderReactions(messageId, reactions);
});

socket.on("typing", ({ name }) => {
  typingEl.textContent = name + " is typing...";
});

socket.on("stop-typing", () => {
  typingEl.textContent = "";
});

function sendMessage() {
  const text = inputEl.value.trim();
  if (!text) return;

  socket.emit("send-message", {
    roomId: ROOM_ID,
    text
  });

  socket.emit("stop-typing", { roomId: ROOM_ID });
  inputEl.value = "";
}

sendBtn.addEventListener("click", sendMessage);

inputEl.addEventListener("keypress", (e) => {
  if (e.key === "Enter") sendMessage();
});

let typingTimeout;

inputEl.addEventListener("input", () => {
  socket.emit("typing", { roomId: ROOM_ID });

  clearTimeout(typingTimeout);
  typingTimeout = setTimeout(() => {
    socket.emit("stop-typing", { roomId: ROOM_ID });
  }, 1000);
});


// <% messages.forEach(msg => { %>
//   renderReactions("<%= msg._id %>", <%- JSON.stringify(msg.reactions || {}) %>);
// <% }) %>

</script>

<%- include('../partials/footer') %>