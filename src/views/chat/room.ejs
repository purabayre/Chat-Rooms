<%- include('../partials/header') %>

<style>

.chat-layout {
  display: flex;
  height: 90vh;
  gap: 28px;
  padding: 28px;
  font-family: 'Inter', 'Segoe UI', sans-serif;
  background: linear-gradient(120deg, #eef2f7, #f8fafc);
}



.chat-sidebar {
  width: 300px;
  padding: 20px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  border: 1px solid rgba(255,255,255,0.4);
  display: flex;
  flex-direction: column;
}

.sidebar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18px;
}

.invite-section {
  margin-bottom: 20px;
}

.hint {
  font-size: 12px;
  color: #6b7280;
}

.invite-copy-row {
  display: flex;
  gap: 6px;
  margin-top: 6px;
}

.invite-link-input {
  flex: 1;
  font-size: 12px;
  padding: 8px;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
}



.online-users-section h4 {
  margin-bottom: 10px;
  font-weight: 600;
}

.online-count-badge {
  background: #dcfce7;
  color: #166534;
  padding: 3px 8px;
  border-radius: 999px;
  font-size: 12px;
}

.online-user {
  font-size: 13px;
  padding: 6px 0;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}



.chat-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  border-radius: 18px;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(14px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  border: 1px solid rgba(255,255,255,0.4);
}



.messages-wrap {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
}

.messages {
  display: flex;
  flex-direction: column;
  gap: 14px;
}


.message-row {
  display: flex;
  align-items: flex-start; 
  gap: 10px;
}

.message-row.mine {
  flex-direction: row-reverse;
}



.avatar-sm {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  flex-shrink: 0;
}



.message-bubble-wrap {
  max-width: 65%;
  position: relative;
  display: flex;
  flex-direction: column;
}

.message-sender {
  font-size: 11px;
  color: #6b7280;
  margin-bottom: 2px;
}

.message-bubble {
  padding: 10px 14px;
  border-radius: 16px;
  font-size: 14px;
  background: rgba(255,255,255,0.9);
  box-shadow: 0 4px 14px rgba(0,0,0,0.05);
}

.message-row.mine .message-bubble {
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: white;
}

.message-time {
  font-size: 10px;
  color: #9ca3af;
  margin-top: 3px;
}



.system-msg {
  text-align: center;
  font-size: 12px;
  color: #9ca3af;
}



.typing-indicator {
  font-size: 12px;
  color: #6b7280;
  padding: 8px 20px;
}



.chat-input-bar {
  display: flex;
  padding: 14px;
  border-top: 1px solid rgba(0,0,0,0.05);
}

.chat-input {
  flex: 1;
  padding: 10px 14px;
  border-radius: 999px;
  border: 1px solid #e5e7eb;
  font-size: 14px;
  margin-right: 10px;
}

.chat-input:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
}



.btn {
  border-radius: 10px;
  font-size: 14px;
  padding: 8px 14px;
  cursor: pointer;
  border: none;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: white;
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 20px rgba(99,102,241,0.35);
}

.btn-ghost {
  background: #f3f4f6;
  color: #374151;
}

.btn-ghost:hover {
  background: #e5e7eb;
}

.btn-sm {
  padding: 6px 10px;
  font-size: 12px;
}



.reaction-popup {
  position: absolute;
  bottom: 80%;
  left: 0;
  transform: translateY(-6px);
  background: #fff;
  border-radius: 20px;
  padding: 4px 8px;
  display: flex;
  gap: 6px;
  box-shadow: 0 6px 16px rgba(0,0,0,0.1);
  opacity: 0;
  pointer-events: none;
  transition: 0.2s ease;
}

.message-bubble-wrap:hover .reaction-popup {
  opacity: 1;
  pointer-events: auto;
}

.reaction-popup button {
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 16px;
}



.reactions {
  margin-top: 4px;
  display: flex;
  flex-wrap: wrap;
}

.reaction-pill {
  background: #eef2ff;
  border-radius: 999px;
  padding: 2px 8px;
  font-size: 12px;
}



.mention {
  background: #fde68a;
  padding: 2px 5px;
  border-radius: 4px;
  font-weight: 600;
}

.message-row.mine .mention {
  background: rgba(255,255,255,0.25);
  color: white;
}

</style><div class="chat-layout">
  <aside class="chat-sidebar">
    <div class="sidebar-header">
      <h3>#<%= room.name %></h3>
      <a href="/chat" class="btn btn-ghost btn-sm">Back to Rooms</a>
    </div>

   

    <div class="online-users-section">
      <h4>Online <span id="online-count" class="online-count-badge">-</span></h4>
      <ul id="online-list" class="online-list"></ul>
    </div>
  </aside>

  <div class="chat-main">

    <div class="messages-wrap" id="messages-wrap">

      <button id="load-more-btn" class="btn btn-ghost btn-sm" style="width:100%; margin-bottom:10px; display:none;">
        Load older messages
      </button>

      <div id="messages" class="messages">
        <% messages.forEach(msg => { %>
          <div class="message-row <%= msg.sender._id.toString() === currentUserId ? 'mine' : 'theirs' %>">
          <img
              src="<%= msg.sender.avatarPath && msg.sender.avatarPath.trim() !== '' 
                    ? msg.sender.avatarPath 
                    : `https://ui-avatars.com/api/?name=${encodeURIComponent(msg.sender.name)}` %>"
                   alt="<%= msg.sender.name %>"
                   class="avatar avatar-sm"
             />
            <div class="message-bubble-wrap">

              <% if (msg.sender._id.toString() !== currentUserId) { %>
                <span class="message-sender"><%= msg.sender.name %></span>
              <% } %>

              <div class="reaction-popup">
                <button onclick="react('<%= msg._id %>', '👍')">👍</button>
                <button onclick="react('<%= msg._id %>', '❤️')">❤️</button>
                <button onclick="react('<%= msg._id %>', '😂')">😂</button>
              </div>

              <div class="message-bubble"><%= msg.text %></div>

              <div class="reactions" id="react-<%= msg._id %>">
                <% if (msg.reactions) { %>
                  <% Object.keys(msg.reactions).forEach(emoji => { %>
                    <% const count = msg.reactions[emoji].length; %>
                    <% if (count > 0) { %>
                      <span class="reaction-pill"><%= emoji %> <%= count %></span>
                    <% } %>
                  <% }) %>
                <% } %>
              </div>

              <span class="message-time">
                <%= new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) %>
              </span>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="typing-indicator" id="typing-indicator"></div>

    <div class="chat-input-bar">
      <input
        type="text"
        id="msg-input"
        class="chat-input"
        placeholder="Type a message…"
        autocomplete="off"
        maxlength="2000"
      />
      <button id="send-btn" class="btn btn-primary">Send</button>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>

<script>
const ROOM_ID      = '<%= room._id %>';
const CURRENT_UID  = '<%= currentUserId %>';
const INVITE_TOKEN = '<%= inviteToken || "" %>';



const socket = io();
const messagesEl = document.getElementById('messages');
const wrapEl  = document.getElementById('messages-wrap');
const inputEl = document.getElementById('msg-input');
const sendBtn = document.getElementById('send-btn');
const typingEl = document.getElementById('typing-indicator');
const loadMoreBtn = document.getElementById("load-more-btn");

let hasMore = true;
let oldestMessageTime = null;
let loadingOlder = false;

/* FIX: prevent duplicate rendering */
let initialLoaded = false;


function scrollBottom() { wrapEl.scrollTop = wrapEl.scrollHeight; }

function formatTime(d) {
  return new Date(d).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

function escapeHtml(str) {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function formatMentions(text) {
  return escapeHtml(text).replace(
    /@([a-zA-Z0-9_]+)/g,
    '<span class="mention">@$1</span>'
  );
}

function appendMessage(msg) {
  const isMine = msg.sender._id === CURRENT_UID || String(msg.sender._id) === CURRENT_UID;

  const row = document.createElement('div');
  row.className = 'message-row ' + (isMine ? 'mine' : 'theirs');

  row.innerHTML = `
    <img 
      src="${
        msg.sender.avatarPath && msg.sender.avatarPath.trim() !== ''
          ? msg.sender.avatarPath
          : `https://ui-avatars.com/api/?name=${encodeURIComponent(msg.sender.name)}`
      }"
      onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(msg.sender.name)}';"
      alt="${escapeHtml(msg.sender.name)}" 
      class="avatar avatar-sm" 
    />
    <div class="message-bubble-wrap">
      ${!isMine ? `<span class="message-sender">${escapeHtml(msg.sender.name)}</span>` : ``}

      <div class="reaction-popup">
        <button onclick="react('${msg._id}', '👍')">👍</button>
        <button onclick="react('${msg._id}', '❤️')">❤️</button>
        <button onclick="react('${msg._id}', '😂')">😂</button>
      </div>

      <div class="message-bubble" data-id="${msg._id}">
        ${formatMentions(msg.text)}
      </div>

      <div class="reactions" id="react-${msg._id}"></div>

      <span class="message-time">${formatTime(msg.createdAt)}</span>
    </div>`;

  messagesEl.appendChild(row);
  scrollBottom();

  renderReactions(msg._id, msg.reactions || {});
}

function prependMessage(msg) {
  const isMine = msg.sender._id === CURRENT_UID || String(msg.sender._id) === CURRENT_UID;

  const row = document.createElement('div');
  row.className = 'message-row ' + (isMine ? 'mine' : 'theirs');

  row.innerHTML = `
    <img 
      src="${
        msg.sender.avatarPath && msg.sender.avatarPath.trim() !== ''
          ? msg.sender.avatarPath
          : `https://ui-avatars.com/api/?name=${encodeURIComponent(msg.sender.name)}`
      }"
      onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(msg.sender.name)}';"
      alt="${escapeHtml(msg.sender.name)}" 
      class="avatar avatar-sm" 
    />
    <div class="message-bubble-wrap">
      <span class="message-sender">${escapeHtml(msg.sender.name)}</span>

      <div class="reaction-popup">
        <button onclick="react('${msg._id}', '👍')">👍</button>
        <button onclick="react('${msg._id}', '❤️')">❤️</button>
        <button onclick="react('${msg._id}', '😂')">😂</button>
      </div>

      <div class="message-bubble">
        ${formatMentions(msg.text)}
      </div>

      <div class="reactions" id="react-${msg._id}"></div>

      <span class="message-time">${formatTime(msg.createdAt)}</span>
    </div>`;

  messagesEl.prepend(row);

  renderReactions(msg._id, msg.reactions || {});
}

function react(messageId, emoji) {
  socket.emit("react-message", {
    roomId: ROOM_ID,
    messageId,
    emoji
  });
}

function renderReactions(messageId, reactions) {
  const container = document.getElementById(`react-${messageId}`);
  if (!container) return;

  container.innerHTML = "";

  for (let emoji in reactions) {
    const users = reactions[emoji];
    const count = users.length;

    const span = document.createElement("span");
    span.className = "reaction-pill";
    span.textContent = `${emoji} ${count}`;

    container.appendChild(span);
  }
}

function appendSystemMessage(text) {
  const div = document.createElement("div");
  div.className = "system-msg";
  div.textContent = text;

  messagesEl.appendChild(div);
  scrollBottom();
}

socket.on("online-users", ({ roomId, users, count }) => {
  const countEl = document.getElementById("online-count");
  const listEl = document.getElementById("online-list");

  if (countEl) countEl.textContent = count;

  if (listEl) {
    listEl.innerHTML = "";

    users.forEach((name) => {
      const li = document.createElement("li");
      li.className = "online-user";
      li.textContent = name;
      listEl.appendChild(li);
    });
  }
});

socket.on("user-joined", ({ name }) => {
  appendSystemMessage(`${name} joined the room`);
});

socket.on("user-left", ({ name }) => {
  appendSystemMessage(`${name} left the room`);
});

socket.emit("join-room", { roomId: ROOM_ID });

socket.on("room-history", (data) => {
  if (initialLoaded) return;
  initialLoaded = true;

  const { messages, hasMore: more, nextBefore } = data;

  hasMore = more;
  oldestMessageTime = nextBefore;

  if (hasMore) {
    loadMoreBtn.style.display = "block";
  } else {
    loadMoreBtn.style.display = "none";
  }
});

function loadOlderMessages() {
  if (!oldestMessageTime) return;

  loadingOlder = true;
  loadMoreBtn.disabled = true;
  loadMoreBtn.innerText = "Loading...";

  socket.emit("load-older-messages", {
    roomId: ROOM_ID,
    before: oldestMessageTime
  });

  setTimeout(() => {
    loadingOlder = false;
    loadMoreBtn.disabled = false;
    loadMoreBtn.innerText = "Load older messages";
  }, 500);
}

loadMoreBtn.addEventListener("click", () => {
  if (!hasMore || loadingOlder) return;
  loadOlderMessages();
});

socket.on("older-messages", (data) => {
  const { messages, hasMore: more, nextBefore } = data;

  hasMore = more;
  oldestMessageTime = nextBefore;

  if (!hasMore) {
    loadMoreBtn.style.display = "none";
  }

  if (!messages.length) return;

  const prevScrollHeight = wrapEl.scrollHeight;

  messages.forEach((msg) => {
    prependMessage(msg);
  });

  wrapEl.scrollTop = wrapEl.scrollHeight - prevScrollHeight;
});

socket.on("new-message", (msg) => {
  appendMessage(msg);
});

socket.on("message-reaction-updated", ({ messageId, reactions }) => {
  renderReactions(messageId, reactions);
});

socket.on("typing", ({ name }) => {
  typingEl.textContent = name + " is typing...";
});

socket.on("stop-typing", () => {
  typingEl.textContent = "";
});

socket.on("mention-notification", ({ from, message }) => {
  alert(`@mention from ${from}: ${message}`);
});

function sendMessage() {
  const text = inputEl.value.trim();
  if (!text) return;

  socket.emit("send-message", {
    roomId: ROOM_ID,
    text
  });

  socket.emit("stop-typing", { roomId: ROOM_ID });
  inputEl.value = "";
}

sendBtn.addEventListener("click", sendMessage);

inputEl.addEventListener("keypress", (e) => {
  if (e.key === "Enter") sendMessage();
});

let typingTimeout;

inputEl.addEventListener("input", () => {
  socket.emit("typing", { roomId: ROOM_ID });

  clearTimeout(typingTimeout);
  typingTimeout = setTimeout(() => {
    socket.emit("stop-typing", { roomId: ROOM_ID });
  }, 1000);
});

window.addEventListener("load", () => {
  setTimeout(() => {
    wrapEl.scrollTop = wrapEl.scrollHeight;
  }, 100);
});
</script>