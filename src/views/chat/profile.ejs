<%- include('../partials/header') %>

<style>
.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  background: #f5f7fa;
  font-family: Arial, sans-serif;
}

.auth-card {
  background: #ffffff;
  padding: 30px 25px;
  width: 100%;
  max-width: 400px;
  border-radius: 10px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
}

.auth-card h2 {
  text-align: center;
  margin-bottom: 20px;
  color: #333;
}

.profile-avatar-preview {
  display: flex;
  justify-content: center;
  margin-bottom: 15px;
}

.avatar-lg {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid #e6e6e6;
}

.form-group {
  margin-bottom: 15px;
}

.form-group label {
  display: block;
  font-size: 14px;
  margin-bottom: 5px;
  color: #555;
}

.hint {
  font-size: 12px;
  color: #888;
}

.form-group input[type="text"],
.form-group input[type="file"] {
  width: 100%;
  padding: 9px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
  background: #fff;
}

.form-group input:focus {
  border-color: #4a90e2;
  outline: none;
}

.btn {
  padding: 10px;
  border: none;
  border-radius: 6px;
  font-size: 15px;
  cursor: pointer;
}

.btn-primary {
  background: #4a90e2;
  color: white;
}

.btn-primary:hover {
  background: #357abd;
}

.btn-block {
  width: 100%;
}

.alert-error {
  background: #ffe5e5;
  color: #d8000c;
  padding: 10px;
  border-radius: 5px;
  margin-bottom: 10px;
  font-size: 14px;
}

.alert-success {
  background: #e6f4ea;
  color: #2e7d32;
  padding: 10px;
  border-radius: 5px;
  margin-bottom: 10px;
  font-size: 14px;
}

/* Footer link */
.auth-alt {
  text-align: center;
  margin-top: 15px;
  font-size: 14px;
}

.auth-alt a {
  color: #4a90e2;
  text-decoration: none;
}

.auth-alt a:hover {
  text-decoration: underline;
}
</style>

<div class="auth-container">
  <div class="auth-card">
    <h2>Edit profile</h2>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div class="profile-avatar-preview">
      <img
        src="<%= user.avatarPath || '/img/default-avatar.png' %>"
        alt="Your avatar"
        class="avatar avatar-lg"
        id="avatar-preview"
      />
    </div>

    <form action="/auth/profile" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label for="name">Display name</label>
        <input type="text" id="name" name="name" value="<%= user.name %>" required maxlength="50" />
      </div>
      <div class="form-group">
        <label for="avatar">New avatar <span class="hint">(optional, max 2MB)</span></label>
        <input type="file" id="avatar" name="avatar" accept="image/*" onchange="previewAvatar(this)" />
      </div>
      <button type="submit" class="btn btn-primary btn-block">Save changes</button>
    </form>
    <p class="auth-alt"><a href="/chat">← Back to rooms</a></p>
  </div>
</div>

<script>
function previewAvatar(input) {
  if (input.files && input.files[0]) {
    const file = input.files[0];

    // Size validation (2MB)
    if (file.size > 2 * 1024 * 1024) {
      alert("File must be less than 2MB");
      input.value = "";
      return;
    }

    const reader = new FileReader();
    reader.onload = e => document.getElementById('avatar-preview').src = e.target.result;
    reader.readAsDataURL(file);
  }
}
</script>

<%- include('../partials/footer') %>