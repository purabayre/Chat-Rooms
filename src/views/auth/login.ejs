<%- include('../partials/header') %>

<style>
/* Container */
.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  background: #f5f7fa;
  font-family: Arial, sans-serif;
}

/* Card */
.auth-card {
  background: #ffffff;
  padding: 30px 25px;
  width: 100%;
  max-width: 380px;
  border-radius: 10px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
}

/* Title */
.auth-card h2 {
  text-align: center;
  margin-bottom: 20px;
  color: #333;
}

/* Form */
.form-group {
  margin-bottom: 15px;
}

.form-group label {
  display: block;
  font-size: 14px;
  margin-bottom: 5px;
  color: #555;
}

.form-group input {
  width: 100%;
  padding: 10px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 14px;
  transition: border 0.3s;
}

.form-group input:focus {
  border-color: #4a90e2;
  outline: none;
}

/* Button */
.btn {
  padding: 10px;
  border: none;
  border-radius: 6px;
  font-size: 15px;
  cursor: pointer;
}

.btn-primary {
  background: #4a90e2;
  color: white;
  transition: background 0.3s;
}

.btn-primary:hover {
  background: #357abd;
}

.btn-block {
  width: 100%;
}

/* Error alert */
.alert-error {
  background: #ffe5e5;
  color: #d8000c;
  padding: 10px;
  border-radius: 5px;
  margin-bottom: 15px;
  font-size: 14px;
}

/* Footer text */
.auth-alt {
  text-align: center;
  margin-top: 15px;
  font-size: 14px;
}

.auth-alt a {
  color: #4a90e2;
  text-decoration: none;
}

.auth-alt a:hover {
  text-decoration: underline;
}
</style>

<div class="auth-container">
  <div class="auth-card">
    <h2>Log in</h2>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="••••••••" />
      </div>
      <button type="submit" class="btn btn-primary btn-block">Log in</button>
    </form>
    <p class="auth-alt">Don't have an account? <a href="/auth/register">Register</a></p>
  </div>
</div>

<%- include('../partials/footer') %>