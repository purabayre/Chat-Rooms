<%- include('../partials/header') %>

<style>

.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 85vh;
  padding: 20px;
  background: linear-gradient(120deg, #eef2f7, #f8fafc);
  font-family: 'Inter', 'Segoe UI', sans-serif;
}

/* GLASS CARD */

.auth-card {
  width: 100%;
  max-width: 420px;
  padding: 28px 24px;
  border-radius: 18px;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(255,255,255,0.4);
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
}

.auth-card h2 {
  text-align: center;
  margin-bottom: 22px;
  font-weight: 600;
  color: #111827;
}

/* FORM */

.form-group {
  margin-bottom: 16px;
}

.form-group label {
  font-size: 13px;
  color: #6b7280;
}

.hint {
  font-size: 12px;
  color: #9ca3af;
}

/* INPUTS */

.form-group input[type="text"],
.form-group input[type="email"],
.form-group input[type="password"],
.form-group input[type="file"] {
  width: 95%;
  padding: 10px;
  margin-top: 6px;
  border-radius: 10px;
  border: 1px solid #e5e7eb;
  background: #fff;
  font-size: 14px;
  transition: all 0.2s ease;
}

.form-group input:focus {
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
  outline: none;
}

.form-group input[type="file"] {
  padding: 6px;
}

/* AVATAR */

.avatar-preview {
  margin-top: 12px;
  text-align: center;
}

.avatar-preview img {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
  display: none;
  border: 2px solid #e5e7eb;
}

/* BUTTONS (MATCH ROOMS UI) */

.btn {
  border-radius: 10px;
  font-size: 14px;
  padding: 10px 14px;
  cursor: pointer;
  border: none;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  color: white;
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 20px rgba(99,102,241,0.35);
}

.btn-block {
  width: 100%;
}

/* ERROR */

.alert-error {
  background: #fee2e2;
  color: #991b1b;
  padding: 10px;
  border-radius: 10px;
  margin-bottom: 16px;
  font-size: 13px;
  border: 1px solid #fecaca;
}

/* FOOTER */

.auth-alt {
  text-align: center;
  margin-top: 18px;
  font-size: 14px;
  color: #6b7280;
}

.auth-alt a {
  color: #4f46e5;
  text-decoration: none;
  font-weight: 500;
}

.auth-alt a:hover {
  text-decoration: underline;
}

</style>

<div class="auth-container">
  <div class="auth-card">
    <h2>Create account</h2>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form action="/auth/register" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label for="name">Display name</label>
        <input type="text" id="name" name="name" required maxlength="50" placeholder="Your name" />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" />
      </div>
      <div class="form-group">
        <label for="password">Password <span class="hint">(min 8 chars)</span></label>
        <input type="password" id="password" name="password" required minlength="8" placeholder="••••••••" />
      </div>
      <div class="form-group">
        <label for="avatar">Avatar <span class="hint">(optional, max 2MB)</span></label>
        <input type="file" id="avatar" name="avatar" accept="image/*" />
        
        <!-- Preview -->
        <div class="avatar-preview">
          <img id="avatarPreview" />
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Register</button>
    </form>
    <p class="auth-alt">Already have an account? <a href="/auth/login">Log in</a></p>
  </div>
</div>

<script>
  const avatarInput = document.getElementById('avatar');
  const preview = document.getElementById('avatarPreview');

  avatarInput.addEventListener('change', function () {
    const file = this.files[0];

    if (file) {
      if (file.size > 2 * 1024 * 1024) {
        alert("File must be less than 2MB");
        avatarInput.value = "";
        preview.style.display = "none";
        return;
      }

      const reader = new FileReader();
      reader.onload = function (e) {
        preview.src = e.target.result;
        preview.style.display = "block";
      };
      reader.readAsDataURL(file);
    }
  });
</script>

<%- include('../partials/footer') %>